<%- include('../../partials/head', { title }) %>
<%- include('../partials/nav') %>
<main class="container admin-claims-page">
  <h1><%= title %></h1>
  <p class="hint"><a href="/admin/fiscal-years">← 회계연도 목록</a></p>
  <table class="data-table claims-admin-table">
    <thead>
      <tr>
        <th class="claims-seq-col">순서</th>
        <th>청구번호</th>
        <th>청구자</th>
        <th>금액</th>
        <th>항목</th>
        <th>상태</th>
        <th>영수증</th>
        <th>청구일시(KST)</th>
      </tr>
    </thead>
    <tbody>
      <% if (claims.length === 0) { %>
        <tr>
          <td colspan="8">등록된 청구가 없습니다.</td>
        </tr>
      <% } %>
      <% claims.forEach((row) => { %>
        <tr>
          <td class="claims-seq-col"><%= row.claimSequence %></td>
          <td><%= row.claimNo %></td>
          <td><%= row.claimantName %></td>
          <td><%= row.amountWon %></td>
          <td class="claims-item-path"><%= row.itemPath %></td>
          <td><%= row.statusLabel %></td>
          <td class="claims-thumbs-cell">
            <div class="claims-thumbs">
              <% row.attachments.forEach((att) => { %>
                <a href="/admin/claim-attachments/<%= att.id %>" target="_blank" rel="noopener noreferrer" class="claims-thumb-link">
                  <img src="/admin/claim-attachments/<%= att.id %>" alt="영수증" class="claims-thumb" width="72" height="72" loading="lazy" />
                </a>
              <% }) %>
            </div>
          </td>
          <td class="claims-datetime"><%= row.claimAtKst %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</main>
<%- include('../../partials/foot') %>
